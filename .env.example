# Copy this file to .env for local development.
# Do NOT commit .env (real secrets).

# Flask / logging
FLASK_DEBUG=false
LOG_LEVEL=INFO

# Preferred DB connection (optional; takes precedence when set)
# Example: mysql+pymysql://stock_user:change_me@mysql:3306/stock_backtest
DATABASE_URL=

# Fallback DB connection parts (used when DATABASE_URL is empty)
DB_HOST=mysql
DB_PORT=3306
DB_NAME=stock_backtest
DB_USER=stock_user
DB_PASSWORD=change_me

# MySQL container bootstrap secret
MYSQL_ROOT_PASSWORD=change_me_root
