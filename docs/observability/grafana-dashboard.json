{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "type": "datasource",
      "pluginId": "prometheus",
      "label": "Prometheus"
    }
  ],
  "__requires": [
    {
      "type": "grafana",
      "id": "grafana",
      "name": "Grafana",
      "version": "10.0.0"
    },
    {
      "type": "datasource",
      "id": "prometheus",
      "name": "Prometheus",
      "version": "1.0.0"
    },
    {
      "type": "panel",
      "id": "row",
      "name": "Row",
      "version": ""
    },
    {
      "type": "panel",
      "id": "timeseries",
      "name": "Time series",
      "version": ""
    },
    {
      "type": "panel",
      "id": "stat",
      "name": "Stat",
      "version": ""
    },
    {
      "type": "panel",
      "id": "barchart",
      "name": "Bar chart",
      "version": ""
    },
    {
      "type": "panel",
      "id": "gauge",
      "name": "Gauge",
      "version": ""
    }
  ],
  "title": "Platform Observability Overview",
  "uid": "platform-observability-overview",
  "version": 1,
  "schemaVersion": 39,
  "editable": true,
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "refresh": "30s",
  "annotations": {
    "list": []
  },
  "templating": {
    "list": [
      {
        "name": "endpoint",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "${DS_PROMETHEUS}"
        },
        "query": "label_values(http_requests_total, endpoint)",
        "definition": "label_values(http_requests_total, endpoint)",
        "refresh": 1,
        "multi": true,
        "includeAll": true,
        "hide": 0,
        "current": {
          "selected": false,
          "text": "All",
          "value": "$__all"
        },
        "sort": 1
      },
      {
        "name": "rule_type",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "${DS_PROMETHEUS}"
        },
        "query": "label_values(backtest_requests_total, rule_type)",
        "definition": "label_values(backtest_requests_total, rule_type)",
        "refresh": 1,
        "multi": true,
        "includeAll": true,
        "hide": 0,
        "current": {
          "selected": false,
          "text": "All",
          "value": "$__all"
        },
        "sort": 1
      }
    ]
  },
  "panels": [
    {
      "type": "row",
      "title": "Web API Health",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false,
      "panels": []
    },
    {
      "type": "timeseries",
      "title": "HTTP Request Rate",
      "description": "Requests per second by method and endpoint. Intentionally unfiltered for global overview.",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 1 },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total[5m])) by (method, endpoint)",
          "legendFormat": "{{method}} {{endpoint}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 10,
            "showPoints": "auto",
            "spanNulls": false
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] }
      }
    },
    {
      "type": "stat",
      "title": "5xx Error Rate",
      "description": "Platform-wide SLO indicator (target: <1%). Intentionally unfiltered. Shows 0% when denominator is near-zero.",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "gridPos": { "h": 8, "w": 4, "x": 12, "y": 1 },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{status=~\"5..\"}[5m])) / clamp_min(sum(rate(http_requests_total[5m])), 1e-9) * 100",
          "legendFormat": "5xx Error Rate",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          },
          "noValue": "No Traffic"
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "value_and_name"
      }
    },
    {
      "type": "timeseries",
      "title": "Request Latency Percentiles",
      "description": "p50/p95/p99 latency distribution. Requires http_request_duration_seconds to be registered as a Prometheus Histogram type. The Prometheus client library automatically exposes _bucket, _sum, and _count sub-series for Histogram metrics. The _bucket series is what histogram_quantile() operates on. If the application implements this metric as a Summary or Gauge instead, the _bucket series will not exist and this panel will show 'No data'.",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 1 },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(http_request_duration_seconds_bucket{endpoint=~\"${endpoint:regex}\"}[5m])) by (le))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket{endpoint=~\"${endpoint:regex}\"}[5m])) by (le))",
          "legendFormat": "p95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(http_request_duration_seconds_bucket{endpoint=~\"${endpoint:regex}\"}[5m])) by (le))",
          "legendFormat": "p99",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 5,
            "showPoints": "auto",
            "spanNulls": false
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      }
    },
    {
      "type": "timeseries",
      "title": "Requests by Status Code",
      "description": "Request rate by HTTP status code. Filtered by $endpoint.",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 9 },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{endpoint=~\"${endpoint:regex}\"}[5m])) by (status)",
          "legendFormat": "{{status}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 30,
            "stacking": { "mode": "normal" },
            "showPoints": "never",
            "spanNulls": false
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "200" },
            "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "400" },
            "properties": [{ "id": "color", "value": { "fixedColor": "yellow", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "500" },
            "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }]
          }
        ]
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      }
    },
    {
      "type": "row",
      "title": "Backtest Execution Pipeline",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 17 },
      "collapsed": false,
      "panels": []
    },
    {
      "type": "timeseries",
      "title": "Backtest Submissions",
      "description": "Submission rate by outcome (accepted/rejected). Filtered by $rule_type.",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 18 },
      "targets": [
        {
          "expr": "sum(rate(backtest_requests_total{rule_type=~\"${rule_type:regex}\"}[5m])) by (outcome)",
          "legendFormat": "{{outcome}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 10,
            "showPoints": "auto",
            "spanNulls": false
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "accepted" },
            "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "rejected" },
            "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }]
          }
        ]
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      }
    },
    {
      "type": "gauge",
      "title": "Backtest Acceptance Rate",
      "description": "Percentage of backtests passing validation. Shows 0% when denominator is near-zero.",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "gridPos": { "h": 8, "w": 4, "x": 8, "y": 18 },
      "targets": [
        {
          "expr": "sum(rate(backtest_requests_total{outcome=\"accepted\", rule_type=~\"${rule_type:regex}\"}[5m])) / clamp_min(sum(rate(backtest_requests_total{rule_type=~\"${rule_type:regex}\"}[5m])), 1e-9) * 100",
          "legendFormat": "Acceptance Rate",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "green", "value": 90 }
            ]
          },
          "noValue": "No Data"
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      }
    },
    {
      "type": "timeseries",
      "title": "Job Launch Outcomes",
      "description": "Job launch attempts recorded by the web application (success vs failure rate). Filtered by $rule_type. Based on application-level counters, not Kubernetes Job object state.",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "gridPos": { "h": 8, "w": 8, "x": 12, "y": 18 },
      "targets": [
        {
          "expr": "sum(rate(job_launch_success_total{rule_type=~\"${rule_type:regex}\"}[5m]))",
          "legendFormat": "Success",
          "refId": "A"
        },
        {
          "expr": "sum(rate(job_launch_failure_total{rule_type=~\"${rule_type:regex}\"}[5m]))",
          "legendFormat": "Failure",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 10,
            "showPoints": "auto",
            "spanNulls": false
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Success" },
            "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "Failure" },
            "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }]
          }
        ]
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      }
    },
    {
      "type": "stat",
      "title": "Job Launch Failure Ratio",
      "description": "Percentage of Job launches that fail. Should be 0% under normal operation.",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "gridPos": { "h": 8, "w": 4, "x": 20, "y": 18 },
      "targets": [
        {
          "expr": "sum(rate(job_launch_failure_total{rule_type=~\"${rule_type:regex}\"}[5m])) / clamp_min(sum(rate(job_launch_success_total{rule_type=~\"${rule_type:regex}\"}[5m])) + sum(rate(job_launch_failure_total{rule_type=~\"${rule_type:regex}\"}[5m])), 1e-9) * 100",
          "legendFormat": "Failure Ratio",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          },
          "noValue": "No Launches"
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "value_and_name"
      }
    },
    {
      "type": "barchart",
      "title": "Submissions by Strategy",
      "description": "Distribution of accepted backtests by rule type.",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 26 },
      "targets": [
        {
          "expr": "sum(rate(backtest_requests_total{outcome=\"accepted\"}[5m])) by (rule_type)",
          "legendFormat": "{{rule_type}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {
            "fillOpacity": 80
          }
        },
        "overrides": []
      },
      "options": {
        "orientation": "horizontal",
        "showValue": "auto",
        "legend": { "displayMode": "list", "placement": "bottom" }
      }
    },
    {
      "type": "row",
      "title": "Job Orchestration Health",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 34 },
      "collapsed": false,
      "panels": []
    },
    {
      "type": "stat",
      "title": "Successful Launches",
      "description": "Successful job launches recorded by the web layer. Uses application-level counters because successful K8s Jobs are deleted quickly and kube_job_status_succeeded is unreliable as a cumulative counter.",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "gridPos": { "h": 8, "w": 4, "x": 0, "y": 35 },
      "targets": [
        {
          "expr": "sum(increase(job_launch_success_total[5m]))",
          "legendFormat": "Succeeded",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null }
            ]
          },
          "noValue": "0"
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "value_and_name"
      }
    },
    {
      "type": "stat",
      "title": "Failed Launches",
      "description": "Failed job launches recorded by the web layer. Uses application-level counters for accurate tracking independent of K8s Job object lifecycle.",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "gridPos": { "h": 8, "w": 4, "x": 4, "y": 35 },
      "targets": [
        {
          "expr": "sum(increase(job_launch_failure_total[5m]))",
          "legendFormat": "Failed",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          },
          "noValue": "0"
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "value_and_name"
      }
    },
    {
      "type": "gauge",
      "title": "Job Launch Success Rate",
      "description": "SLO target: ≥95%. Based on application-level launch counters (not K8s Job object state). Shows 'No Launches' when no data is available.",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "gridPos": { "h": 8, "w": 4, "x": 8, "y": 35 },
      "targets": [
        {
          "expr": "sum(increase(job_launch_success_total[5m])) / clamp_min(sum(increase(job_launch_success_total[5m])) + sum(increase(job_launch_failure_total[5m])), 1e-9) * 100",
          "legendFormat": "Success Rate",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 80 },
              { "color": "green", "value": 95 }
            ]
          },
          "noValue": "No Jobs"
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      }
    },
    {
      "type": "barchart",
      "title": "Pod Restart Count",
      "description": "Total restarts per pod, sorted descending. Zero = healthy.",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 35 },
      "targets": [
        {
          "expr": "sort_desc(sum(kube_pod_container_status_restarts_total{namespace=\"stock-backtest\"}) by (pod))",
          "legendFormat": "{{pod}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          },
          "custom": {
            "fillOpacity": 80
          }
        },
        "overrides": []
      },
      "options": {
        "orientation": "horizontal",
        "showValue": "always",
        "legend": { "displayMode": "hidden" }
      }
    },
    {
      "type": "timeseries",
      "title": "Failed / Retained Job Duration",
      "description": "Per-Job duration (completion_time - start_time) for Jobs still present in the cluster. Successful Jobs are deleted quickly by the web application after completion, so this panel mainly captures failed or retained Jobs useful for debugging. Do not use this panel to infer overall execution success statistics.",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 35 },
      "targets": [
        {
          "expr": "kube_job_status_completion_time{namespace=\"stock-backtest\"} - kube_job_status_start_time{namespace=\"stock-backtest\"}",
          "legendFormat": "{{job_name}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "drawStyle": "points",
            "pointSize": 8,
            "showPoints": "always",
            "spanNulls": false
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "single", "sort": "none" },
        "legend": { "displayMode": "hidden" }
      }
    },
    {
      "type": "row",
      "title": "Platform Infrastructure Health",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 43 },
      "collapsed": false,
      "panels": []
    },
    {
      "type": "timeseries",
      "title": "Web Pod CPU Usage",
      "description": "CPU consumption of Web Deployment pods. Values are in CPU cores (e.g., 0.1 = 100m = 10% of 1 core).",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 44 },
      "targets": [
        {
          "expr": "sum(rate(container_cpu_usage_seconds_total{namespace=\"stock-backtest\", pod=~\"web-.*\"}[5m])) by (pod)",
          "legendFormat": "{{pod}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 15,
            "showPoints": "never",
            "spanNulls": false
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      }
    },
    {
      "type": "timeseries",
      "title": "Web Pod Memory Usage",
      "description": "Memory consumption of Web pods. Watch for steady increases (memory leak).",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 44 },
      "targets": [
        {
          "expr": "sum(container_memory_working_set_bytes{namespace=\"stock-backtest\", pod=~\"web-.*\"}) by (pod)",
          "legendFormat": "{{pod}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 15,
            "showPoints": "never",
            "spanNulls": false
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      }
    },
    {
      "type": "timeseries",
      "title": "Worker CPU Usage",
      "description": "CPU consumption of Worker Job pods during backtest execution. Values are in CPU cores (e.g., 0.1 = 100m = 10% of 1 core).",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 52 },
      "targets": [
        {
